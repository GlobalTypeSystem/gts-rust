{
  "$id": "gts://gts.x.test.golden.event.v1~",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "description": "Base event",
  "properties": {
    "id": {
      "description": "GTS instance identifier",
      "format": "gts-instance-id",
      "title": "GTS Instance ID",
      "type": "string",
      "x-gts-ref": "gts.*"
    },
    "payload": {
      "type": "object"
    }
  },
  "required": [
    "id",
    "payload"
  ],
  "type": "object",
  "x-gts-abstract": true,
  "x-gts-traits-schema": {
    "properties": {
      "escalation": {
        "properties": {
          "after": {
            "type": "string"
          },
          "to": {
            "enum": [
              "Low",
              "High"
            ],
            "type": "string"
          }
        },
        "required": [
          "after",
          "to"
        ],
        "type": "object"
      },
      "indexed": {
        "const": true,
        "type": "boolean"
      },
      "retention": {
        "default": "P30D",
        "type": "string"
      },
      "severity": {
        "enum": [
          "Low",
          "High"
        ],
        "type": "string"
      },
      "topic_ref": {
        "type": "string",
        "x-gts-ref": "gts.x.core.events.topic.v1~"
      }
    },
    "required": [
      "topic_ref",
      "indexed",
      "severity",
      "escalation"
    ],
    "type": "object"
  }
}
