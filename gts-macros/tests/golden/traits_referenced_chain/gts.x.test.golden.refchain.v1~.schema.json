{
  "$id": "gts://gts.x.test.golden.refchain.v1~",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "description": "Base host referencing the base priority trait type",
  "properties": {
    "id": {
      "description": "GTS instance identifier",
      "format": "gts-instance-id",
      "title": "GTS Instance ID",
      "type": "string",
      "x-gts-ref": "gts.*"
    },
    "payload": {
      "type": "object"
    }
  },
  "required": [
    "id",
    "payload"
  ],
  "type": "object",
  "x-gts-abstract": true,
  "x-gts-traits-schema": {
    "allOf": [
      {
        "$ref": "gts://gts.x.test.traits.priority.v1~"
      }
    ],
    "type": "object"
  }
}
