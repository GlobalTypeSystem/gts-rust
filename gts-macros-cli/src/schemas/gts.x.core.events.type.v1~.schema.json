{
  "$id": "gts://gts.x.core.events.type.v1~",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "description": "Base event type definition",
  "properties": {
    "id": {
      "format": "uuid",
      "type": "string"
    },
    "payload": {
      "type": "object"
    },
    "sequence_id": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "tenant_id": {
      "format": "uuid",
      "type": "string"
    },
    "type": {
      "description": "GTS type identifier",
      "format": "gts-type-id",
      "title": "GTS Type ID",
      "type": "string",
      "x-gts-ref": "gts.*"
    }
  },
  "required": [
    "type",
    "id",
    "tenant_id",
    "sequence_id",
    "payload"
  ],
  "type": "object",
  "x-gts-abstract": true,
  "x-gts-traits-schema": {
    "additionalProperties": false,
    "properties": {
      "retention": {
        "default": "P30D",
        "type": "string"
      },
      "topic_ref": {
        "type": "string",
        "x-gts-ref": "gts.x.core.events.topic.v1~"
      }
    },
    "required": [
      "topic_ref"
    ],
    "type": "object"
  }
}
